// ─── COSMOS CANVAS ───────────────────────────────────────
(function initCosmos(){
  const canvas = document.getElementById('cosmos-canvas');
  const ctx = canvas.getContext('2d');
  let W, H, stars=[], clouds=[], galaxies=[];

  function resize(){
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // Stars
  for(let i=0;i<350;i++){
    stars.push({
      x: Math.random(), y: Math.random(),
      r: Math.random()*1.8+.2,
      a: Math.random(),
      speed: Math.random()*.003+.001,
      color: ['#ffffff','#e8f0ff','#ccd9ff','#a78bfa','#60efff','#f0c040'][Math.floor(Math.random()*6)]
    });
  }

  // Nebula clouds
  for(let i=0;i<12;i++){
    clouds.push({
      x: Math.random(), y: Math.random(),
      rx: 80+Math.random()*200, ry: 60+Math.random()*150,
      angle: Math.random()*Math.PI,
      a: .015+Math.random()*.025,
      color: ['rgba(120,40,220,','rgba(30,80,220,','rgba(220,60,120,','rgba(96,239,255,','rgba(167,139,250,'][Math.floor(Math.random()*5)],
      drift: (Math.random()-.5)*.0003
    });
  }

  // Mini galaxies (spiral dots)
  for(let i=0;i<6;i++){
    const arms=[], cx=Math.random(), cy=Math.random();
    for(let j=0;j<80;j++){
      const t=j/80, arm=Math.floor(Math.random()*3);
      const angle=t*Math.PI*4 + arm*Math.PI*2/3;
      const r=(40+Math.random()*20)*t;
      arms.push({dx:Math.cos(angle)*r, dy:Math.sin(angle)*r, a:t*.6});
    }
    galaxies.push({cx, cy, arms, rot:0, speed:(Math.random()-.5)*.0002});
  }

  let tick=0;
  function draw(){
    ctx.clearRect(0,0,W,H);

    // Nebula clouds
    clouds.forEach(c=>{
      c.angle += c.drift;
      ctx.save();
      ctx.translate(c.x*W, c.y*H);
      ctx.rotate(c.angle);
      const g=ctx.createRadialGradient(0,0,0,0,0,c.rx);
      g.addColorStop(0,c.color+c.a+')');
      g.addColorStop(1,c.color+'0)');
      ctx.fillStyle=g;
      ctx.scale(1, c.ry/c.rx);
      ctx.beginPath();
      ctx.arc(0,0,c.rx,0,Math.PI*2);
      ctx.fill();
      ctx.restore();
    });

    // Mini galaxies
    galaxies.forEach(gal=>{
      gal.rot += gal.speed;
      ctx.save();
      ctx.translate(gal.cx*W, gal.cy*H);
      ctx.rotate(gal.rot);
      gal.arms.forEach(p=>{
        ctx.globalAlpha=p.a*.3;
        ctx.fillStyle='#a78bfa';
        ctx.beginPath();
        ctx.arc(p.dx, p.dy, .8, 0, Math.PI*2);
        ctx.fill();
      });
      ctx.restore();
    });
    ctx.globalAlpha=1;

    // Stars
    tick+=.016;
    stars.forEach(s=>{
      s.a += s.speed;
      const alpha = (.4 + Math.sin(s.a)*.5);
      ctx.globalAlpha = alpha;
      ctx.fillStyle = s.color;
      ctx.beginPath();
      ctx.arc(s.x*W, s.y*H, s.r, 0, Math.PI*2);
      ctx.fill();

      // Bright stars get a cross sparkle
      if(s.r>1.4){
        ctx.globalAlpha = alpha*.4;
        ctx.strokeStyle = s.color;
        ctx.lineWidth = .5;
        ctx.beginPath();
        ctx.moveTo(s.x*W - s.r*4, s.y*H);
        ctx.lineTo(s.x*W + s.r*4, s.y*H);
        ctx.moveTo(s.x*W, s.y*H - s.r*4);
        ctx.lineTo(s.x*W, s.y*H + s.r*4);
        ctx.stroke();
      }
    });
    ctx.globalAlpha=1;
    requestAnimationFrame(draw);
  }
  draw();
})();

