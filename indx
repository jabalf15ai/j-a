})();

// ─── REVEAL ──────────────────────────────────────────────
const revObs = new IntersectionObserver(es=>{
  es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');revObs.unobserve(e.target);}});
},{threshold:.06,rootMargin:'0px 0px -20px 0px'});
document.querySelectorAll('.rv').forEach(el=>revObs.observe(el));

// ─── COUNTERS ────────────────────────────────────────────
const ctrObs = new IntersectionObserver(es=>{
  es.forEach(e=>{
    if(e.isIntersecting){
      const el=e.target, target=parseInt(el.dataset.target)||0;
      const dur=1600, start=performance.now();
      (function up(now){
        const p=Math.min((now-start)/dur,1);
        const ease=1-Math.pow(1-p,3);
        el.textContent=Math.round(ease*target);
        if(target===300&&p>=1)el.textContent='300+';
        if(p<1)requestAnimationFrame(up);
      })(start);
      ctrObs.unobserve(el);
    }
  });
},{threshold:.5});
document.querySelectorAll('.ctr[data-target]').forEach(el=>ctrObs.observe(el));

