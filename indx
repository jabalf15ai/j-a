<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>أنس اللهيبي الحربي | السيرة الذاتية الكونية</title>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=IBM+Plex+Mono:wght@400;600;700&family=Noto+Kufi+Arabic:wght@400;700;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
:root{
  --cosmos:#00000f;
  --deep:#040420;
  --nebula1:rgba(120,40,220,.18);
  --nebula2:rgba(30,80,220,.15);
  --nebula3:rgba(220,60,120,.12);
  --star:#e8f0ff;
  --plasma:#a78bfa;
  --aurora:#60efff;
  --flame:#fb923c;
  --gold:#f0c040;
  --emerald:#34d399;
  --panel:rgba(10,8,40,.7);
  --edge:rgba(120,80,255,.12);
  --edgeh:rgba(120,80,255,.35);
  --txt:#d4d8f0;
  --txt2:#8890b8;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Tajawal',sans-serif;background:var(--cosmos);color:var(--txt);overflow-x:hidden;cursor:none}

/* ───── CURSOR ───── */
#cursor{position:fixed;width:18px;height:18px;border-radius:50%;border:2px solid var(--plasma);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:transform .12s,width .2s,height .2s;mix-blend-mode:screen}
#cursor-trail{position:fixed;width:6px;height:6px;border-radius:50%;background:var(--aurora);pointer-events:none;z-index:99998;transform:translate(-50%,-50%);opacity:.5;transition:all .05s}

/* ───── CANVAS ───── */
#cosmos-canvas{position:fixed;inset:0;z-index:0;pointer-events:none}

/* ───── NEBULA ORBS ───── */
.neb{position:fixed;border-radius:50%;filter:blur(100px);pointer-events:none;z-index:1;animation:nebDrift 30s ease-in-out infinite}
.neb-a{width:70vw;height:70vw;top:-20%;right:-15%;background:radial-gradient(circle,rgba(120,40,220,.2),transparent 65%)}
.neb-b{width:55vw;height:55vw;bottom:-15%;left:-10%;background:radial-gradient(circle,rgba(30,80,220,.18),transparent 65%);animation-delay:-15s}
.neb-c{width:40vw;height:40vw;top:40%;left:30%;background:radial-gradient(circle,rgba(220,60,120,.1),transparent 65%);animation-delay:-8s}
@keyframes nebDrift{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(30px,-20px) scale(1.05)}66%{transform:translate(-20px,30px) scale(.95)}}

/* ───── SCROLLBAR ───── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--cosmos)}
::-webkit-scrollbar-thumb{background:var(--plasma);border-radius:8px}
::selection{background:var(--plasma);color:#fff}

/* ───── NAV ───── */
nav{position:fixed;top:0;width:100%;z-index:50;background:rgba(4,4,32,.85);backdrop-filter:blur(24px);border-bottom:1px solid var(--edge)}
.nav-inner{max-width:1280px;margin:0 auto;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.nav-logo{display:flex;align-items:center;gap:12px}
.av-wrap{position:relative}
.av-wrap img{width:42px;height:42px;border-radius:12px;object-fit:cover;border:2px solid rgba(167,139,250,.4);box-shadow:0 0 20px rgba(167,139,250,.2)}
.av-ring{position:absolute;inset:-5px;border-radius:16px;border:1px solid rgba(167,139,250,.2);animation:avSpin 8s linear infinite}
@keyframes avSpin{to{transform:rotate(360deg)}}
.av-dot{position:absolute;bottom:-2px;right:-2px;width:10px;height:10px;background:var(--emerald);border-radius:50%;border:2px solid var(--cosmos);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(52,211,153,.4)}50%{box-shadow:0 0 0 6px rgba(52,211,153,0)}}
.nav-name{font-family:'Noto Kufi Arabic',sans-serif;font-weight:900;font-size:15px;color:#fff;line-height:1.2}
.nav-sub{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--plasma);letter-spacing:.2em;text-transform:uppercase}
.nav-links{display:flex;align-items:center;gap:4px;font-size:12px;font-weight:700}
.nav-links a{padding:7px 14px;border-radius:10px;color:var(--txt2);transition:all.3s;text-decoration:none}
.nav-links a:hover{color:#fff;background:rgba(167,139,250,.08)}
.nav-cta{padding:8px 18px;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;border-radius:10px;font-weight:800;font-size:12px;text-decoration:none;transition:all.3s;box-shadow:0 0 20px rgba(124,58,237,.3)}
.nav-cta:hover{box-shadow:0 0 30px rgba(167,139,250,.5);transform:translateY(-1px)}
@media(max-width:768px){.nav-links{display:none}}

/* ───── SECTIONS ───── */
section{position:relative;z-index:2}

/* ───── HERO ───── */
.hero{min-height:100vh;display:flex;align-items:center;padding:100px 24px 80px;overflow:hidden}
.hero-inner{max-width:1280px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 360px;gap:80px;align-items:center}
@media(max-width:1024px){.hero-inner{grid-template-columns:1fr}}

/* ORBIT SYSTEM */
.orbit-sys{position:absolute;top:50%;left:-5%;transform:translateY(-50%);width:900px;height:900px;pointer-events:none;opacity:.4}
.orbit-ring{position:absolute;border-radius:50%;border:1px solid rgba(167,139,250,.15);top:50%;left:50%;transform:translate(-50%,-50%)}
.orbit-ring:nth-child(1){width:200px;height:200px;animation:orbitSpin 20s linear infinite}
.orbit-ring:nth-child(2){width:380px;height:380px;animation:orbitSpin 35s linear infinite reverse}
.orbit-ring:nth-child(3){width:560px;height:560px;animation:orbitSpin 55s linear infinite}
.orbit-ring:nth-child(4){width:740px;height:740px;animation:orbitSpin 80s linear infinite reverse}
.orbit-ring:nth-child(5){width:900px;height:900px;animation:orbitSpin 110s linear infinite}
@keyframes orbitSpin{to{transform:translate(-50%,-50%) rotate(360deg)}}
.orbit-planet{position:absolute;border-radius:50%;top:-5px;left:50%}
.orbit-ring:nth-child(1) .orbit-planet{width:10px;height:10px;background:var(--gold);box-shadow:0 0 15px var(--gold);margin-left:-5px}
.orbit-ring:nth-child(2) .orbit-planet{width:8px;height:8px;background:var(--aurora);box-shadow:0 0 12px var(--aurora);margin-left:-4px}
.orbit-ring:nth-child(3) .orbit-planet{width:12px;height:12px;background:var(--plasma);box-shadow:0 0 18px var(--plasma);margin-left:-6px}
.orbit-ring:nth-child(4) .orbit-planet{width:7px;height:7px;background:var(--flame);box-shadow:0 0 12px var(--flame);margin-left:-3.5px}
.orbit-ring:nth-child(5) .orbit-planet{width:9px;height:9px;background:var(--emerald);box-shadow:0 0 14px var(--emerald);margin-left:-4.5px}

.tag-badge{display:inline-flex;align-items:center;gap:8px;padding:6px 16px;border-radius:999px;background:rgba(167,139,250,.06);border:1px solid rgba(167,139,250,.15);margin-bottom:28px;font-size:11px;font-weight:700;color:var(--plasma)}
.tag-dot{width:7px;height:7px;border-radius:50%;background:var(--plasma);animation:pulse 2s infinite}
.hero-title{font-family:'Noto Kufi Arabic',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:900;line-height:1.1;margin-bottom:24px}
.gr-aurora{background:linear-gradient(135deg,#60efff,#4ade80,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.gr-flame{background:linear-gradient(135deg,#fb923c,#f59e0b,#ef4444);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.gr-cosmos{background:linear-gradient(135deg,#a78bfa,#60efff);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-desc{color:var(--txt2);font-size:15px;line-height:1.8;max-width:580px;margin-bottom:36px;border-right:2px solid rgba(167,139,250,.3);padding-right:16px}
.hero-desc strong{color:#fff}
.hero-btns{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px}
.btn-primary{background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;padding:14px 28px;border-radius:14px;font-weight:900;font-size:13px;cursor:pointer;border:none;transition:all.3s;box-shadow:0 0 25px rgba(124,58,237,.3)}
.btn-primary:hover{box-shadow:0 0 40px rgba(167,139,250,.5);transform:translateY(-2px)}
.btn-ghost{background:rgba(10,8,40,.8);border:1px solid var(--edge);color:var(--txt);padding:14px 28px;border-radius:14px;font-weight:700;font-size:13px;cursor:pointer;transition:all.3s}
.btn-ghost:hover{border-color:var(--edgeh);color:#fff;transform:translateY(-2px)}
.hero-stats{display:flex;flex-wrap:wrap;gap:12px}
.stat-chip{display:flex;align-items:center;gap:10px;padding:10px 18px;background:rgba(10,8,40,.8);border:1px solid var(--edge);border-radius:14px}
.stat-num{font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:700}
.stat-lbl{font-size:9px;color:var(--txt2);line-height:1.4}

/* ─ CARD ─ */
.hero-card{background:rgba(10,8,40,.8);backdrop-filter:blur(24px);border:1px solid var(--edge);border-radius:20px;overflow:hidden;transition:all.4s}
.hero-card:hover{border-color:var(--edgeh);transform:translateY(-6px);box-shadow:0 20px 60px rgba(0,0,0,.6)}
.card-banner{height:96px;position:relative;background:linear-gradient(135deg,#3b0764,#7c3aed,#1d4ed8)}
.card-banner::after{content:'';position:absolute;inset:0;background-image:radial-gradient(circle at 1px 1px,rgba(255,255,255,.08) 1px,transparent 0);background-size:14px 14px}
.card-av-wrap{position:absolute;bottom:-40px;left:50%;transform:translateX(-50%)}
.card-av-wrap img{width:80px;height:80px;border-radius:18px;object-fit:cover;border:4px solid var(--cosmos);box-shadow:0 0 30px rgba(124,58,237,.3)}
.card-body{padding:56px 20px 24px;text-align:center}
.card-name{font-family:'Noto Kufi Arabic',sans-serif;font-size:16px;font-weight:900;color:#fff;margin-bottom:4px}
.card-role{color:var(--plasma);font-weight:700;font-size:12px;margin-bottom:16px}
.card-tags{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:16px}
.ctag{padding:3px 10px;border-radius:8px;font-size:9px;font-weight:700;border:1px solid}
.ctag-p{border-color:rgba(167,139,250,.25);color:var(--plasma);background:rgba(167,139,250,.06)}
.ctag-e{border-color:rgba(52,211,153,.25);color:var(--emerald);background:rgba(52,211,153,.06)}
.ctag-g{border-color:rgba(240,192,64,.25);color:var(--gold);background:rgba(240,192,64,.06)}
.card-divider{height:1px;background:linear-gradient(to left,transparent,rgba(255,255,255,.06),transparent);margin-bottom:16px}
.card-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;text-align:center}
.cg-val{font-family:'IBM Plex Mono',monospace;font-size:18px;font-weight:700;margin-bottom:2px}
.cg-lbl{font-size:8px;color:var(--txt2)}

/* ───── SECTION HEADERS ───── */
.sec-head{max-width:1280px;margin:0 auto;padding:0 24px;margin-bottom:48px}
.sec-badge{display:inline-flex;align-items:center;gap:8px;padding:5px 16px;border-radius:999px;font-size:10px;font-weight:700;margin-bottom:16px;border:1px solid}
.sec-title{font-family:'Noto Kufi Arabic',sans-serif;font-size:clamp(1.8rem,3vw,3rem);font-weight:900;color:#fff;line-height:1.2}
.sec-sub{color:var(--txt2);font-size:13px;margin-top:8px;max-width:520px}

/* ───── METRICS ───── */
.sec-metrics{padding:80px 0;scroll-margin-top:80px}
.kpi-grid{max-width:1280px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
@media(max-width:768px){.kpi-grid{grid-template-columns:repeat(2,1fr)}}
.kpi-card{background:rgba(10,8,40,.7);backdrop-filter:blur(20px);border:1px solid var(--edge);border-radius:16px;padding:20px;text-align:center;cursor:pointer;transition:all.3s}
.kpi-card.act{border-color:rgba(167,139,250,.4);background:rgba(124,58,237,.08)}
.kpi-card:hover{transform:translateY(-4px);border-color:var(--edgeh)}
.kpi-icon{font-size:24px;margin-bottom:8px}
.kpi-val{font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:700;margin-bottom:4px}
.kpi-lbl{font-size:10px;font-weight:700;opacity:.8}
.kpi-detail{max-width:1280px;margin:0 auto;padding:0 24px}
.kpi-box{background:rgba(10,8,40,.7);border:1px solid var(--edge);border-right:4px solid var(--plasma);border-radius:16px;padding:20px;font-size:13px;line-height:1.8;color:var(--txt2);transition:opacity.3s}

/* ───── SKILLS ───── */
.sec-skills{padding:80px 0;scroll-margin-top:80px}
.skills-inner{max-width:1280px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
@media(max-width:768px){.skills-inner{grid-template-columns:1fr}}
.skills-glass{background:rgba(10,8,40,.7);backdrop-filter:blur(20px);border:1px solid var(--edge);border-radius:20px;padding:28px}
.skills-title{font-size:13px;font-weight:900;color:var(--plasma);margin-bottom:20px}
.skill-item{display:flex;align-items:center;gap:12px;padding:12px 14px;border-radius:12px;background:rgba(4,4,32,.6);border:1px solid rgba(255,255,255,.03);font-size:13px;color:var(--txt);margin-bottom:10px}
.skill-item span:first-child{font-size:16px}
.radar-wrap{height:380px}

/* ───── TIMELINE ───── */
.sec-timeline{padding:80px 0;scroll-margin-top:80px}
.tl-wrap{max-width:1280px;margin:0 auto;padding:0 24px;position:relative}
.tl-spine{position:absolute;right:50%;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--plasma),var(--aurora),var(--emerald));opacity:.3}
@media(max-width:768px){.tl-spine{right:20px}}
.tl-item{display:flex;margin-bottom:56px;position:relative}
.tl-item:nth-child(odd){justify-content:flex-end;padding-left:calc(50% + 48px)}
.tl-item:nth-child(even){padding-right:calc(50% + 48px)}
@media(max-width:768px){.tl-item,.tl-item:nth-child(odd),.tl-item:nth-child(even){padding:0 0 0 52px;justify-content:flex-start}}
.tl-node{position:absolute;right:calc(50% - 10px);top:20px;width:20px;height:20px;border-radius:50%;border:3px solid var(--cosmos);z-index:3;box-shadow:0 0 20px currentColor}
@media(max-width:768px){.tl-node{right:auto;left:8px}}
.tl-card{background:rgba(10,8,40,.8);backdrop-filter:blur(20px);border:1px solid var(--edge);border-radius:16px;padding:24px;max-width:460px;width:100%;transition:all.3s}
.tl-card:hover{border-color:var(--edgeh);transform:translateY(-4px);box-shadow:0 16px 50px rgba(0,0,0,.5)}
.tl-date{font-family:'IBM Plex Mono',monospace;font-size:10px;font-weight:700;margin-bottom:6px}
.tl-title{font-size:15px;font-weight:900;color:#fff;margin-bottom:8px}
.tl-desc{font-size:12px;color:var(--txt2);line-height:1.7}

/* ───── TOOLS ───── */
.sec-tools{padding:80px 0;scroll-margin-top:80px}
.tools-inner{max-width:1280px;margin:0 auto;padding:0 24px;display:flex;gap:20px;align-items:flex-start}
@media(max-width:768px){.tools-inner{flex-direction:column}}
.tool-sidebar{width:240px;flex-shrink:0;background:rgba(10,8,40,.7);backdrop-filter:blur(20px);border:1px solid var(--edge);border-radius:20px;padding:8px;display:flex;flex-direction:column;gap:2px}
@media(max-width:768px){.tool-sidebar{width:100%;flex-direction:row;flex-wrap:wrap;overflow-x:auto}}
.tb{cursor:pointer;padding:10px 14px;border-radius:12px;font-size:12px;font-weight:700;color:var(--txt2);border:none;background:transparent;display:flex;align-items:center;gap:8px;transition:all.3s;border-right:3px solid transparent;text-align:right;white-space:nowrap}
.tb:hover{background:rgba(167,139,250,.05);color:var(--txt)}
.tb.act{background:rgba(167,139,250,.08);border-right-color:var(--plasma);color:var(--plasma)}
.tool-main{flex:1;background:rgba(10,8,40,.8);backdrop-filter:blur(20px);border:1px solid var(--edge);border-top:3px solid var(--emerald);border-radius:20px;padding:28px;min-height:460px;display:flex;flex-direction:column}
.tv{display:none;flex:1;flex-direction:column;animation:fadeUp.4s ease}
.tv.act{display:flex}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
.tv-title{font-size:17px;font-weight:900;color:#fff;margin-bottom:6px}
.tv-sub{font-size:11px;color:var(--txt2);margin-bottom:20px}
.tool-input-row{display:flex;gap:10px;margin-bottom:12px}
.tool-input{flex:1;background:rgba(4,4,32,.8);border:1px solid rgba(167,139,250,.1);border-radius:12px;padding:12px 16px;font-size:13px;color:#fff;font-family:'Tajawal',sans-serif;outline:none;transition:border-color.3s}
.tool-input:focus{border-color:rgba(167,139,250,.4)}
.tool-btn-run{background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;padding:12px 20px;border-radius:12px;font-weight:900;font-size:12px;border:none;cursor:pointer;transition:all.3s;white-space:nowrap}
.tool-btn-run:hover{box-shadow:0 0 20px rgba(167,139,250,.4);transform:translateY(-1px)}
.tool-btn-run:disabled{opacity:.5;cursor:not-allowed;transform:none}
.tool-out{display:none;flex:1;background:rgba(4,4,32,.8);border:1px solid rgba(255,255,255,.04);border-radius:14px;padding:16px;font-size:13px;color:var(--txt2);line-height:1.8;overflow-y:auto}
.tool-out.vis{display:block}
.file-inp{font-size:12px;color:var(--txt2)}
.file-inp::file-selector-button{margin-inline-end:12px;padding:8px 14px;border-radius:10px;border:none;font-size:11px;font-weight:700;background:rgba(167,139,250,.1);color:var(--plasma);cursor:pointer}

/* ───── CHAT ───── */
.chat-btn{position:fixed;bottom:24px;right:24px;z-index:100;width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,#7c3aed,#a78bfa);color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;cursor:pointer;border:none;box-shadow:0 4px 30px rgba(124,58,237,.5);transition:transform.3s}
.chat-btn:hover{transform:scale(1.12)}
.chat-win{position:fixed;bottom:96px;right:24px;width:370px;max-width:calc(100vw - 48px);height:520px;background:rgba(4,4,32,.95);backdrop-filter:blur(30px);border:1px solid rgba(167,139,250,.15);border-radius:24px;z-index:99;display:flex;flex-direction:column;box-shadow:0 20px 80px rgba(0,0,0,.8);overflow:hidden;transform:translateY(120%) scale(.95);opacity:0;pointer-events:none;transition:all.45s cubic-bezier(.4,0,.2,1)}
.chat-win.open{transform:none;opacity:1;pointer-events:all}
.chat-head{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.04);display:flex;align-items:center;gap:12px;background:rgba(10,8,40,.9)}
.chat-av{width:36px;height:36px;border-radius:10px;background:rgba(124,58,237,.15);border:1px solid rgba(167,139,250,.2);display:flex;align-items:center;justify-content:center;font-family:'IBM Plex Mono',monospace;font-size:11px;font-weight:700;color:var(--plasma)}
.chat-hname{font-size:13px;font-weight:900;color:#fff}
.chat-hsub{font-family:'IBM Plex Mono',monospace;font-size:8px;color:var(--plasma)}
.chat-close{margin-right:auto;background:none;border:none;color:var(--txt2);font-size:20px;cursor:pointer;padding:0 8px;transition:color.2s}
.chat-close:hover{color:#fff}
.chat-hist{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:10px}
.chat-hist::-webkit-scrollbar{width:3px}
.chat-hist::-webkit-scrollbar-thumb{background:var(--plasma);border-radius:4px}
.msg-bot{max-width:88%;align-self:flex-start;padding:10px 14px;background:rgba(10,8,40,.9);border:1px solid rgba(255,255,255,.04);border-radius:14px 14px 14px 2px;font-size:12px;color:var(--txt);line-height:1.6;animation:msgIn.3s ease}
.msg-usr{max-width:82%;align-self:flex-end;padding:10px 14px;background:linear-gradient(135deg,#7c3aed,#a78bfa);border-radius:14px 14px 2px 14px;font-size:12px;color:#fff;font-weight:700;animation:msgIn.3s ease}
@keyframes msgIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.typing-dots{display:flex;gap:4px;padding:4px 0}
.typing-dots span{width:6px;height:6px;border-radius:50%;background:var(--plasma);animation:dotBounce 1.4s infinite both}
.typing-dots span:nth-child(2){animation-delay:.2s}
.typing-dots span:nth-child(3){animation-delay:.4s}
@keyframes dotBounce{0%,80%,100%{opacity:.2;transform:scale(.7)}40%{opacity:1;transform:scale(1.1)}}
.chat-foot{padding:12px;border-top:1px solid rgba(255,255,255,.04);display:flex;gap:8px;background:rgba(10,8,40,.9)}
.chat-inp{flex:1;background:rgba(4,4,32,.9);border:1px solid rgba(167,139,250,.1);border-radius:12px;padding:10px 14px;font-size:12px;color:#fff;font-family:'Tajawal',sans-serif;outline:none;transition:border-color.3s}
.chat-inp:focus{border-color:rgba(167,139,250,.35)}
