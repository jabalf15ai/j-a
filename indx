async function callAI(text, sys, imageBase64=null, mimeType=null){
  if(!API_KEY||API_KEY==='ضع_مفتاحك_هنا')
    return '⚠️ يرجى إضافة مفتاح Gemini API في متغير API_KEY بالكود.';

  const url=`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${API_KEY}`;
  let parts=[{text}];
  if(imageBase64&&mimeType) parts.push({inlineData:{mimeType,data:imageBase64}});

  try{
    const res=await fetch(url,{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({
        contents:[{parts}],
        systemInstruction:{parts:[{text:sys}]},
        generationConfig:{temperature:.7}
      })
    });
    if(!res.ok) throw new Error(res.status);
    const data=await res.json();
    // ✅ FIX #1: correct JSON path
    return data.candidates[0].content.parts[0].text;
  }catch(err){
    return '⚠️ فشل الاتصال بخوادم جوجل. تأكد من صحة المفتاح. ['+err.message+']';
  }
}

function fmt(t){
  return t
    .replace(/\n/g,'<br>')
    .replace(/\*\*(.*?)\*\*/g,'<strong style="color:var(--plasma)">$1</strong>');
}

async function runTool(type){
  let query='', imgB64=null, mime=null;

  if(type==='vision'){
    const fi=document.getElementById('in-vision-file');
    if(!fi.files.length){alert('الرجاء إرفاق صورة أولاً.');return;}
    // ✅ FIX #2: files[0]
    const file=fi.files[0];
    mime=file.type;
    imgB64=await new Promise(r=>{
      const rd=new FileReader();
      rd.onload=()=>r(rd.result.split(',')[1]);
      rd.readAsDataURL(file);
    });
    query=document.getElementById('in-vision').value.trim()||'حلل هذه الصورة';
  } else if(type==='pitch'){
    const c=document.getElementById('in-pitch-c').value.trim();
    const r=document.getElementById('in-pitch-r').value.trim();
    if(!c||!r)return;
    query=`الشركة: ${c}، الوظيفة: ${r}`;
  } else {
    query=document.getElementById('in-'+type).value.trim();
    if(!query)return;
  }

  const out=document.getElementById('out-'+type);
  const btn=document.querySelector('#tv-'+type+' .tool-btn-run');
  const orig=btn.textContent;
  btn.disabled=true; btn.textContent='جاري...';
  out.classList.add('vis');
  out.innerHTML='<div class="typing-dots"><span></span><span></span><span></span></div>';

  const res=await callAI(query, TOOL_SYS[type], imgB64, mime);
  out.innerHTML=fmt(res);
  btn.disabled=false; btn.textContent=orig;
}

